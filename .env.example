# Przykładowa konfiguracja wdrożenia — skopiuj do `.env` i dostosuj.
# docker compose automatycznie wczytuje plik `.env` z katalogu projektu.

# --- Baza danych ---
POSTGRES_DB=hairbook
POSTGRES_USER=hairbook
# W środowisku produkcyjnym ustaw silne, unikalne hasło:
POSTGRES_PASSWORD=hairbook

# --- Aplikacja ---
# Port hosta, pod którym wystawiona jest aplikacja (kontener zawsze nasłuchuje na 5173):
APP_PORT=5173

# Hasło kont demo zakładanych przy pierwszym seedzie:
DEMO_PASSWORD=1234

# Flaga `Secure` na ciasteczku sesji — ustaw `true`, gdy serwujesz po HTTPS:
COOKIE_SECURE=false

# --- Opcjonalne reguły rezerwacji online (mają wartości domyślne w kodzie) ---
# BOOKING_MIN_LEAD_MINUTES=0
# BOOKING_MAX_ADVANCE_DAYS=120
# SALON_TZ=Europe/Warsaw
